{
  "manifest_version": 3,
  "name": "LinkedIn AI Engagement Assistant",
  "version": "1.2.0",
  "description": "AI-powered like and comment on LinkedIn post notifications. Works only on LinkedIn.",
  "permissions": ["storage", "notifications", "alarms", "scripting", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*", "https://api.anthropic.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "LinkedIn AI Assistant" }
}
